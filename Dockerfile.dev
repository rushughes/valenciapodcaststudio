# Hugo Extended (matches host version) + Go toolchain (Hugo Modules) + Node.
# Pinned for reproducible local builds across machines.
#
# We install Hugo from the official release binary instead of using
# hugomods/hugo because hugomods only publishes up to 0.154.5 and Blowfish
# v2.100+ depends on Hugo APIs that landed in newer versions.
FROM golang:1.25-bookworm

ARG HUGO_VERSION=0.160.1
ARG TARGETARCH

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git rsync nodejs npm \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL "https://github.com/gohugoio/hugo/releases/download/v${HUGO_VERSION}/hugo_extended_${HUGO_VERSION}_linux-${TARGETARCH}.tar.gz" \
        | tar xz -C /usr/local/bin hugo \
    && hugo version

WORKDIR /src
EXPOSE 1313
ENTRYPOINT ["hugo"]
