# Copy to .env.deploy (git-ignored) and fill in. Consumed by Makefile `deploy` target.
# Example shape only — replace everything.

DEPLOY_USER=deploy
DEPLOY_HOST=example.com
DEPLOY_PATH=/var/www/valenciapodcaststudio
DEPLOY_PORT=22
# Optional: path to SSH key if not using default ~/.ssh/id_ed25519
# DEPLOY_KEY=~/.ssh/valenciapodcaststudio_ed25519
